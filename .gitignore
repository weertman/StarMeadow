# StarMeadow publication-repo ignore policy
#
# Goal: keep local exploratory work available on this machine while making the
# GitHub-facing repository sparse, reproducible, and publication-focused.
# If a generated/private file is already tracked, this ignore file will not
# remove it by itself; untrack with `git rm --cached <path>` to keep the local
# copy while removing it from GitHub.

# -----------------------------------------------------------------------------
# OS/editor noise
# -----------------------------------------------------------------------------
.DS_Store
**/.DS_Store
Thumbs.db
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Python/R/Jupyter caches and local environments
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.venv/
venv/
.env/
.conda-env/
conda-meta/

# -----------------------------------------------------------------------------
# Logs, local run artifacts, agent scratch, private correspondence
# -----------------------------------------------------------------------------
*.log
run_all_output.log
logs/
.hermes/
emails/

# -----------------------------------------------------------------------------
# Local archives and opaque bundles
# -----------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
!outputs/publication_figures/share/*.tex

# -----------------------------------------------------------------------------
# Third-party raw ShoreZone FileGDB bundle.
# Publication repo should use source/download instructions or minimal derived
# inputs, not commit the full geodatabase payload unless redistribution is
# explicitly approved.
# -----------------------------------------------------------------------------
data/state_DNR_ShoreZone/*.lyr
data/state_DNR_ShoreZone/*.gdb/
!data/state_DNR_ShoreZone/dnr_shorezone_metadata.html
!data/state_DNR_ShoreZone/dnr_shorezone_metadata.xml

# -----------------------------------------------------------------------------
# Internal manuscript/planning documents.
# Public repo should not expose collaborator working docs or internal strategy.
# -----------------------------------------------------------------------------
docs/Outline.docx
docs/MANUSCRIPT_CONTEXT.md
docs/NEXT_STEPS.md
docs/diver_only_stats_plan_critique.md
docs/publication_repo_cleanup_audit_*.md
README.html

# Old exploratory code kept locally but not on sparse publication GitHub
code/01_encounter_rate_analysis.py
code/02_size_structure_analysis.py
code/03_clustering_analysis.py
code/04_temporal_analysis.py
code/05_statistical_summary.py
code/06_eelgrass_site_analysis.py
code/07_size_clustering_analysis.py
code/08_combined_clustering_analysis.py
code/09_size_prediction_analysis.py
code/10_eelgrass_size_relationship.py
code/11_habitat_diversity_analysis.py
code/12_eelgrass_basin_analysis.py
code/13_static_maps.py
code/14_interactive_maps.py
code/15b_site_coverage_map.py
code/19_probability_density_map.py
code/run_all.py

# -----------------------------------------------------------------------------
# Old exploratory generated outputs: keep local, remove from GitHub.
# Whitelist only the minimal derived ShoreZone CSVs that current publication
# scripts still read directly.
# -----------------------------------------------------------------------------
outputs/*
!outputs/publication_figures/
!outputs/15_shorezone_site_analysis/
outputs/15_shorezone_site_analysis/*
!outputs/15_shorezone_site_analysis/site_shorezone_pycno_summary.csv
!outputs/15_shorezone_site_analysis/shorezone_ZOS_UNIT_proportions.csv
!outputs/16_shorezone_recovery_analysis/
outputs/16_shorezone_recovery_analysis/*
!outputs/16_shorezone_recovery_analysis/feature_importance_permutation.csv

# -----------------------------------------------------------------------------
# Current publication outputs: keep final figures, captions, final stats/tables,
# and compact machine-readable source tables. Ignore intermediate QC, internal
# drafts, manuscript prose, collaborator share bundles, and copy-paste helpers.
# -----------------------------------------------------------------------------
outputs/publication_figures/*
!outputs/publication_figures/submission/
!outputs/publication_figures/sources/
!outputs/publication_figures/stats/
!outputs/publication_figures/supplemental_tables/
!outputs/publication_figures/captions.md

